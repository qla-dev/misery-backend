APP_NAME=Misery Meter
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Required for https://misery.qla.dev/code/{code} Universal/App Links.
IOS_APP_TEAM_ID=
# Comma-separated SHA-256 signing certificate fingerprints (release and optional debug).
ANDROID_APP_SHA256_CERT_FINGERPRINTS=

# Comma-separated OAuth client IDs accepted by the mobile app.
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=misery.qla.dev

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Launch-wave transport. The selected hosted provider is tried first, then the
# other hosted provider, then polling. Valid values: pusher, ably.
REALTIME_PRIMARY_PROVIDER=pusher
INGAME_POLLING_INTERVAL_MS=3000
PUSHER_HEARTBEAT_INTERVAL_MS=20000
PUSHER_CONNECTION_CAPACITY=100
ABLY_CONNECTION_CAPACITY=200
REALTIME_PROVIDER_PROBE_TIMEOUT_MS=2500

# Pusher Sandbox credentials.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Ably API key (full key-name:secret value). Keep this server-side only.
ABLY_API_KEY=

# Strict future transport. When true, every room uses only Laravel Reverb:
# no Pusher, Ably, or periodic polling fallback is used.
REVERB_OVERRIDE=false
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Public websocket hostname on the DigitalOcean droplet (without https://).
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https
# Internal bind address/port used by `php artisan reverb:start` on the droplet.
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# CMS uses the browser's native Basic Auth dialog.
CMS_USERNAME=admin
CMS_PASSWORD=1234

# Required for CMS AI artwork and question generation.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER="${APP_URL}"
OPENROUTER_TITLE="${APP_NAME}"
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_TEXT_MODEL=openai/gpt-4.1-mini

# Main CMS question generator. If GEMINI_API_KEY is empty, the fallback key below is reused.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite

# Direct Google Gemini fallback for CMS artwork when OpenRouter has insufficient credit.
FALLBACK_GEMINI_API_KEY=
FALLBACK_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
FALLBACK_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Public download destinations used by the React landing page.
VITE_APP_STORE_URL=
VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=misery.qla.dev

# RevenueCat secret API key is backend-only. Never expose it to Expo.
REVENUECAT_SECRET_API_KEY=
REVENUECAT_PRO_ENTITLEMENT_ID=misery-pro
